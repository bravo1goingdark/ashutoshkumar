{
  "name": "ashutosh-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "prebuild": "node scripts/og.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "npm run build && npx wrangler@latest pages deploy .svelte-kit/cloudflare --project-name ashutoshk"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^4.9.0",
    "@sveltejs/kit": "^2.20.4",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.4",
    "mdsvex": "^0.11.2",
    "rehype-slug": "^6.0.0",
    "remark-toc": "^9.0.0",
    "sharp": "^0.34.5",
    "svelte": "^5.28.2",
    "svelte-check": "^4.1.5",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.1.1"
  },
  "type": "module"
}
